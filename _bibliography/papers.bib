@article{delis2025jae,
  bibtex_show={true},
  selected={true},
  title   = {Global Evidence on Profit Shifting Within Firms and Across Time},
  author  = {Delis, Fotis and Delis, Manthos D. and Laeven, Luc and Ongena, Steven},
  journal = jae,
  volume  = {79},
  number  = {2},
  year    = {2025},
  doi     = {10.1016/j.jacceco.2024.101744},
  html    = {https://doi.org/10.1016/j.jacceco.2024.101744},
  abbr    = {JAE},
  abstract = {Within a mainstay model of profit shifting, we use a nonparametric approach to produce firm-year, MNE-year, industry-year, and country-year profit-shifting estimates for over two million firm-years across 100 countries between 2009 and 2020. The granularity of the estimates lets us document the size, persistence, and heterogeneity of multinational profit shifting at every level of aggregation, characterise how it evolves with firm- and country-level fundamentals, and quantify how it responds to tax-rate differentials and to specific reforms. We make the country-year and industry-year aggregates publicly available so that other researchers can build on them, and discuss how the methodology can be extended to other firm-level panels and to forward-looking simulation of corporate-tax reforms.}
}

@article{delis2023ear,
  bibtex_show={true},
  selected={true},
  title   = {Corporate Governance and Profit Shifting: The Role of the Audit Committee},
  author  = {Delis, Fotis and Delis, Manthos D. and Karavitis, Panagiotis and Klassen, Kenneth},
  journal = ear,
  volume  = {32},
  pages   = {809--839},
  year    = {2023},
  doi     = {10.1080/09638180.2022.2125385},
  html    = {https://www.tandfonline.com/doi/full/10.1080/09638180.2022.2125385},
  abbr    = {EAR},
  abstract = {We examine how board-level governance shapes the tax-planning aggressiveness of multinational firms. Combining firm-level panel data on multinationals with hand-collected information on audit-committee composition, we show that the size of the audit committee is positively associated with profit shifting, consistent with larger committees enabling more complex inter-affiliate transactions. The relationship is sharply attenuated, and in some specifications reversed, when the committee includes members with audit and accounting expertise. Findings are robust to alternative measures of profit shifting, to controlling for board structure and ownership, and to using exogenous variation in committee composition arising from regulatory changes. We interpret the results as evidence that the audit committee acts as a balancing mechanism between aggressive tax planning and the reputational and regulatory risk it generates.}
}

