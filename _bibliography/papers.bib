@techreport{delis2025pricing,
  bibtex_show={true},
  selected={true},
  title   = {The Pricing of Profit Shifting},
  author  = {Delis, Fotis and Delis, Manthos D. and Kokas, Sotirios and Laeven, Luc and Ongena, Steven},
  year    = {2025},
  type    = {SSRN working paper, under review},
  institution = {SSRN},
  abbr    = {WP},
  abstract = {We test whether equity markets price the risk associated with multinational profit shifting. Using firm-level estimates of profit shifting from Delis et al. (2025), we show that firms with higher levels of profit shifting earn meaningfully higher future stock returns, and that this premium is incremental to standard risk-factor exposures. The premium is concentrated among firms in jurisdictions with stronger enforcement, among firms with greater media and analyst attention, and around regulatory events that raise the salience of cross-border tax planning. Together, the findings are consistent with profit shifting carrying priced regulatory and reputational risk that investors are aware of and demand compensation for. We discuss implications for international corporate-tax policy and for the empirical asset-pricing literature on tax-related risk premia.}
}

